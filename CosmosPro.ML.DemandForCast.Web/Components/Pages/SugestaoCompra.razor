@page "/sugestao-compra"
@rendermode InteractiveServer
@inject PurchasingApiClient PurchasingApi
@inject TrainingApiClient TrainingApi
@inject NotificationService Notifications
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Sugestão de compra</PageTitle>

<RadzenStack Orientation="Orientation.Vertical" Gap="1.5rem">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.H4" Style="margin: 0">Sugestão de compra</RadzenText>
        <HelpTip Position="TooltipPosition.Bottom" Text="@TipPagina" />
        <div style="flex: 1"></div>
    </RadzenStack>

    <RadzenCard Variant="Variant.Outlined">
        <RadzenStack Gap="1rem">
            <RadzenText TextStyle="TextStyle.H6" Style="margin: 0">Nova simulação</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="1rem" AlignItems="AlignItems.End">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenFormField Text="Treino origem" Variant="Variant.Outlined" Style="width: 320px">
                        <RadzenDropDown Data="@_treinosConcluidos" TValue="Guid" @bind-Value="_treinoJobId"
                                        TextProperty="Label" ValueProperty="Id"
                                        Placeholder="Escolha um treino concluído" AllowClear="false" />
                    </RadzenFormField>
                    <HelpTip Text="@TipTreino" />
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenFormField Text="Janela (dias)" Variant="Variant.Outlined" Style="width: 130px">
                        <RadzenNumeric @bind-Value="_janelaDias" Min="14" Max="365" />
                    </RadzenFormField>
                    <HelpTip Text="@TipJanela" />
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenFormField Text="Lead time (dias)" Variant="Variant.Outlined" Style="width: 140px">
                        <RadzenNumeric @bind-Value="_leadTime" Min="1" Max="30" />
                    </RadzenFormField>
                    <HelpTip Text="@TipLeadTime" />
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenFormField Text="Ciclo (dias)" Variant="Variant.Outlined" Style="width: 120px">
                        <RadzenNumeric @bind-Value="_ciclo" Min="1" Max="30" />
                    </RadzenFormField>
                    <HelpTip Text="@TipCiclo" />
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenFormField Text="Fator z" Variant="Variant.Outlined" Style="width: 110px">
                        <RadzenNumeric @bind-Value="_fatorServico" Min="0" Max="4" Step="0.05" />
                    </RadzenFormField>
                    <HelpTip Text="@TipFator" />
                </RadzenStack>
                <RadzenButton Click="@Simular"
                              Icon="@(_enqueuing ? "hourglass_empty" : "play_arrow")"
                              Text="@(_enqueuing ? "Enfileirando…" : "Simular")"
                              ButtonStyle="ButtonStyle.Primary"
                              Disabled="@(_enqueuing || _treinoJobId == Guid.Empty)" />
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>

    <RadzenCard Variant="Variant.Outlined">
        <RadzenStack Gap="1rem">
            <RadzenText TextStyle="TextStyle.H6" Style="margin: 0">Execuções</RadzenText>
            <RadzenDataGrid TItem="SimulacaoView" Data="@_jobs" AllowPaging="true" PageSize="8"
                            Density="Density.Compact" IsLoading="@(_loading && _jobs.Count == 0)"
                            EmptyText="Nenhuma simulação executada ainda."
                            RowSelect="@OnSelect"
                            SelectionMode="DataGridSelectionMode.Single">
                <Columns>
                    <RadzenDataGridColumn TItem="SimulacaoView" Property="Status" Title="Status" Width="130px">
                        <Template Context="j">
                            <RadzenBadge Text="@j.Status" BadgeStyle="@BadgeFor(j.Status)" Shade="Shade.Lighter" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SimulacaoView" Property="DataAgendamento" Title="Agendado" Width="170px">
                        <Template Context="j"><small>@j.DataAgendamento.ToLocalTime().ToString("dd/MM HH:mm:ss")</small></Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SimulacaoView" Property="JanelaDias" Title="Janela" Width="90px" TextAlign="TextAlign.Right">
                        <Template Context="j">@j.JanelaDias d</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SimulacaoView" Property="LeadTimeDias" Title="LT" Width="70px" TextAlign="TextAlign.Right">
                        <Template Context="j">@j.LeadTimeDias d</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SimulacaoView" Property="FatorServico" Title="z" Width="70px" TextAlign="TextAlign.Right">
                        <Template Context="j">@j.FatorServico.ToString("F2")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SimulacaoView" Property="SeriesSimuladas" Title="Séries" Width="100px" TextAlign="TextAlign.Right">
                        <Template Context="j">@(j.SeriesSimuladas?.ToString("N0") ?? "—")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SimulacaoView" Title="Detalhe">
                        <Template Context="j">
                            @if (j.Status == "Falha")
                            {
                                <small style="color: var(--rz-danger)">@j.MensagemErro</small>
                            }
                            else if (j.Status == "Concluido")
                            {
                                <RadzenButton Text="Ver resultado" Icon="bar_chart" Size="ButtonSize.Small"
                                              ButtonStyle="ButtonStyle.Light" Click="@(() => OnSelect(j))" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenStack>
    </RadzenCard>

    @if (_selected is { Status: "Concluido" } && PurchasingApiClient.ParseResultado(_selected.ResultadoJson) is { } so)
    {
        var r = so.Resultado;
        var politicas = r.Politicas;
        var classico = politicas.FirstOrDefault(p => p.Policy == "emax-eseg");
        var ml = politicas.FirstOrDefault(p => p.Policy == "forecast-rop");

        <RadzenCard Variant="Variant.Outlined">
            <RadzenStack Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.H6" Style="margin: 0">Comparativo global das políticas</RadzenText>
                    <HelpTip Text="@TipComparativo" />
                    @if (classico is not null && ml is not null)
                    {
                        var melhorCusto = ml.Global.CustoTotal < classico.Global.CustoTotal ? "forecast-rop" : "emax-eseg";
                        <RadzenBadge Text="@($"melhor custo: {melhorCusto}")" BadgeStyle="BadgeStyle.Success" IsPill="true" />
                    }
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; color: var(--rz-text-secondary-color)">
                    Janela @r.DataInicio.ToString("dd/MM/yyyy") → @r.DataFim.ToString("dd/MM/yyyy")
                    · @r.SeriesAvaliadas SKU×loja · LT @r.LeadTimeDias d · ciclo @r.CicloDias d · z @r.FatorServico.ToString("F2")
                </RadzenText>

                <RadzenDataGrid TItem="PolicySimulationResultView" Data="@politicas" AllowPaging="false" Density="Density.Compact">
                    <Columns>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Property="Policy" Title="Política">
                            <Template Context="p">
                                <strong>@LabelPolitica(p.Policy)</strong>
                                @if (_policyTips.TryGetValue(p.Policy, out var t))
                                {
                                    <HelpTip Text="@t" Size="0.85rem" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Title="Nível de serviço (unid.)" Width="180px" TextAlign="TextAlign.Right">
                            <HeaderTemplate><span>NS (unid.)</span><HelpTip Text="@TipNsUnid" Size="0.85rem" /></HeaderTemplate>
                            <Template Context="p">@p.Global.NivelServicoUnidades.ToString("P1")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Title="NS (dias)" Width="120px" TextAlign="TextAlign.Right">
                            <HeaderTemplate><span>NS (dias)</span><HelpTip Text="@TipNsDias" Size="0.85rem" /></HeaderTemplate>
                            <Template Context="p">@p.Global.NivelServicoDias.ToString("P1")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Title="Venda perdida" Width="140px" TextAlign="TextAlign.Right">
                            <HeaderTemplate><span>Venda perdida</span><HelpTip Text="@TipPerdida" Size="0.85rem" /></HeaderTemplate>
                            <Template Context="p">@p.Global.VendaPerdida.ToString("N0")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Title="Cobertura (d)" Width="140px" TextAlign="TextAlign.Right">
                            <HeaderTemplate><span>Cobertura</span><HelpTip Text="@TipCobertura" Size="0.85rem" /></HeaderTemplate>
                            <Template Context="p">@p.Global.CoberturaMediaDias.ToString("F1")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Title="Giro" Width="100px" TextAlign="TextAlign.Right">
                            <HeaderTemplate><span>Giro</span><HelpTip Text="@TipGiro" Size="0.85rem" /></HeaderTemplate>
                            <Template Context="p">@p.Global.Giro.ToString("F2")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Title="Pedidos" Width="100px" TextAlign="TextAlign.Right">
                            <Template Context="p">@p.Global.Pedidos.ToString("N0")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="PolicySimulationResultView" Title="Custo total" Width="140px" TextAlign="TextAlign.Right">
                            <HeaderTemplate><span>Custo total</span><HelpTip Text="@TipCustoTotal" Size="0.85rem" /></HeaderTemplate>
                            <Template Context="p">@p.Global.CustoTotal.ToString("N2")</Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenStack>
        </RadzenCard>

        <RadzenCard Variant="Variant.Outlined">
            <RadzenStack Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.H6" Style="margin: 0">Drill-down por hierarquia</RadzenText>
                    <HelpTip Text="@TipDrill" />
                </RadzenStack>

                <RadzenTabs RenderMode="TabRenderMode.Client">
                    <Tabs>
                        @foreach (var dim in _dimensions)
                        {
                            var rows = BuildDrillRows(politicas, dim);
                            <RadzenTabsItem Text="@($"{dim} ({rows.Count})")">
                                @if (rows.Count == 0)
                                {
                                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color)">
                                        Sem dados nesta dimensão.
                                    </RadzenText>
                                }
                                else
                                {
                                    <RadzenDataGrid TItem="DrillRow" Data="@rows" AllowPaging="true" PageSize="10" AllowSorting="true" Density="Density.Compact">
                                        <Columns>
                                            <RadzenDataGridColumn TItem="DrillRow" Property="Chave" Title="@dim" />
                                            <RadzenDataGridColumn TItem="DrillRow" Property="Dias" Title="dias-série" Width="120px" TextAlign="TextAlign.Right">
                                                <Template Context="row">@row.Dias.ToString("N0")</Template>
                                            </RadzenDataGridColumn>
                                            @foreach (var pol in politicas.Select(p => p.Policy))
                                            {
                                                var label = LabelPolitica(pol);
                                                <RadzenDataGridColumn TItem="DrillRow" Title="@($"NS {label}")" Width="140px" TextAlign="TextAlign.Right" Sortable="false">
                                                    <Template Context="row">
                                                        @(row.NsByPolicy.TryGetValue(pol, out var n) ? n.ToString("P1") : "—")
                                                    </Template>
                                                </RadzenDataGridColumn>
                                                <RadzenDataGridColumn TItem="DrillRow" Title="@($"Custo {label}")" Width="140px" TextAlign="TextAlign.Right" Sortable="false">
                                                    <Template Context="row">
                                                        @(row.CustoByPolicy.TryGetValue(pol, out var c) ? c.ToString("N2") : "—")
                                                    </Template>
                                                </RadzenDataGridColumn>
                                            }
                                            <RadzenDataGridColumn TItem="DrillRow" Property="VencedorCusto" Title="Vencedor (custo)" Width="170px">
                                                <Template Context="row">
                                                    <RadzenBadge Text="@LabelPolitica(row.VencedorCusto)"
                                                                 BadgeStyle="@(row.VencedorCusto == ForecastPolicyName ? BadgeStyle.Success : BadgeStyle.Secondary)"
                                                                 Shade="Shade.Lighter" />
                                                </Template>
                                            </RadzenDataGridColumn>
                                        </Columns>
                                    </RadzenDataGrid>
                                }
                            </RadzenTabsItem>
                        }
                    </Tabs>
                </RadzenTabs>
            </RadzenStack>
        </RadzenCard>

        var produtos = so.Produtos ?? new Dictionary<string, string>();
        var buyRows = BuildBuyList(politicas, produtos);
        var buyVisiveis = _soItensAPedir ? buyRows.Where(b => b.QtdByPolicy.Values.Any(q => q > 0)).ToList() : buyRows;

        <RadzenCard Variant="Variant.Outlined">
            <RadzenStack Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.H6" Style="margin: 0">Lista de compra</RadzenText>
                    <HelpTip Text="@TipLista" />
                    <div style="flex: 1"></div>
                    <RadzenButton Text="Exportar tudo" Icon="download" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => Exportar(so, s => PurchasingExcelExporter.BuildCompleto(s, _ledgerPolicy ?? politicas.FirstOrDefault()?.Policy), $"sugestao-compra-completo_{r.DataFim:yyyy-MM-dd}.xlsx"))" />
                </RadzenStack>

                <RadzenTabs RenderMode="TabRenderMode.Client">
                    <Tabs>
                        <RadzenTabsItem Text="@($"Sugestão de hoje ({buyVisiveis.Count})")">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="margin-bottom: 0.5rem">
                                <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; color: var(--rz-text-secondary-color)">
                                    Foto do último dia da janela (@r.DataFim.ToString("dd/MM/yyyy")): o que cada política mandaria pedir ao fornecedor "hoje".
                                </RadzenText>
                                <div style="flex: 1"></div>
                                <RadzenCheckBox @bind-Value="_soItensAPedir" Name="soPedir" TValue="bool" />
                                <RadzenLabel Text="Só itens a pedir" Component="soPedir" Style="font-size: 0.85rem" />
                                <RadzenButton Text="Exportar" Icon="download" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => Exportar(so, PurchasingExcelExporter.BuildSugestaoHoje, $"sugestao-compra_{r.DataFim:yyyy-MM-dd}.xlsx"))" />
                            </RadzenStack>
                            @if (buyVisiveis.Count == 0)
                            {
                                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color)">
                                    Nenhum item dispararia pedido no último dia simulado.
                                </RadzenText>
                            }
                            else
                            {
                                <RadzenDataGrid TItem="BuyRow" Data="@buyVisiveis" AllowPaging="true" PageSize="15" AllowSorting="true" Density="Density.Compact">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="BuyRow" Property="Sku" Title="SKU" Width="110px" />
                                        <RadzenDataGridColumn TItem="BuyRow" Property="Nome" Title="Produto" />
                                        <RadzenDataGridColumn TItem="BuyRow" Property="LojaId" Title="Loja" Width="80px" TextAlign="TextAlign.Right" />
                                        @foreach (var pol in politicas.Select(p => p.Policy))
                                        {
                                            var label = LabelPolitica(pol);
                                            <RadzenDataGridColumn TItem="BuyRow" Title="@($"Pos. {label}")" Width="110px" TextAlign="TextAlign.Right" Sortable="false">
                                                <HeaderTemplate><span>Pos. @label</span><HelpTip Text="@TipPosicao" Size="0.8rem" /></HeaderTemplate>
                                                <Template Context="b">@(b.PosicaoByPolicy.TryGetValue(pol, out var pos) ? pos.ToString("N0") : "—")</Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="BuyRow" Title="@($"Pedir {label}")" Width="130px" TextAlign="TextAlign.Right">
                                                <HeaderTemplate><span>Pedir @label</span><HelpTip Text="@TipQtdPedir" Size="0.8rem" /></HeaderTemplate>
                                                <Template Context="b">
                                                    @{ var q = b.QtdByPolicy.GetValueOrDefault(pol); }
                                                    <strong style="@(q > 0 ? "color: var(--rz-primary)" : "color: var(--rz-text-tertiary-color)")">@q.ToString("N0")</strong>
                                                </Template>
                                            </RadzenDataGridColumn>
                                        }
                                        <RadzenDataGridColumn TItem="BuyRow" Title="Δ (ML − clássico)" Width="150px" TextAlign="TextAlign.Right" Sortable="false">
                                            <HeaderTemplate><span>Δ ML − clássico</span><HelpTip Text="@TipDelta" Size="0.8rem" /></HeaderTemplate>
                                            <Template Context="b">
                                                @{
                                                    var qC = b.QtdByPolicy.GetValueOrDefault(ClassicPolicyName);
                                                    var qM = b.QtdByPolicy.GetValueOrDefault(ForecastPolicyName);
                                                    var delta = qM - qC;
                                                }
                                                <span style="@(delta == 0 ? "" : delta > 0 ? "color: var(--rz-warning)" : "color: var(--rz-info)")">
                                                    @(delta > 0 ? "+" : "")@delta.ToString("N0")
                                                </span>
                                            </Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            }
                        </RadzenTabsItem>

                        <RadzenTabsItem Text="Livro de pedidos">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="margin-bottom: 0.5rem">
                                <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; color: var(--rz-text-secondary-color)">
                                    Todo pedido lançado pela política ao longo da janela (auditoria).
                                </RadzenText>
                                <div style="flex: 1"></div>
                                <RadzenLabel Text="Política" Component="polLedger" Style="font-size: 0.85rem" />
                                <RadzenDropDown @bind-Value="_ledgerPolicy" Data="@politicas.Select(p => p.Policy)" Name="polLedger" Style="width: 200px"
                                                Change="@(_ => StateHasChanged())">
                                    <Template Context="pol">@LabelPolitica((string)pol)</Template>
                                </RadzenDropDown>
                                <RadzenButton Text="Exportar" Icon="download" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => Exportar(so, s => PurchasingExcelExporter.BuildLivroPedidos(s, _ledgerPolicy ?? politicas.FirstOrDefault()?.Policy), $"livro-de-pedidos_{r.DataFim:yyyy-MM-dd}.xlsx"))" />
                            </RadzenStack>
                            @{
                                var polSel = _ledgerPolicy ?? politicas.FirstOrDefault()?.Policy;
                                var ped = politicas.FirstOrDefault(p => p.Policy == polSel)?.Pedidos ?? [];
                                var pedOrd = ped.OrderByDescending(o => o.Data).ToList();
                            }
                            @if (pedOrd.Count == 0)
                            {
                                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color)">
                                    Nenhum pedido lançado por esta política na janela.
                                </RadzenText>
                            }
                            else
                            {
                                <RadzenDataGrid TItem="OrderRecordView" Data="@pedOrd" AllowPaging="true" PageSize="15" AllowSorting="true" Density="Density.Compact">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="OrderRecordView" Property="Data" Title="Data" Width="110px">
                                            <Template Context="o">@o.Data.ToString("dd/MM/yyyy")</Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="OrderRecordView" Property="Sku" Title="SKU" Width="110px" />
                                        <RadzenDataGridColumn TItem="OrderRecordView" Title="Produto">
                                            <Template Context="o">@(produtos.GetValueOrDefault(o.Sku) ?? "")</Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="OrderRecordView" Property="LojaId" Title="Loja" Width="80px" TextAlign="TextAlign.Right" />
                                        <RadzenDataGridColumn TItem="OrderRecordView" Property="PosicaoAntes" Title="Posição" Width="100px" TextAlign="TextAlign.Right">
                                            <Template Context="o">@o.PosicaoAntes.ToString("N0")</Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="OrderRecordView" Property="ReorderPoint" Title="Ponto pedido (s)" Width="140px" TextAlign="TextAlign.Right">
                                            <Template Context="o">@o.ReorderPoint.ToString("N0")</Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="OrderRecordView" Property="OrderUpToLevel" Title="Alvo (S)" Width="110px" TextAlign="TextAlign.Right">
                                            <Template Context="o">@o.OrderUpToLevel.ToString("N0")</Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="OrderRecordView" Property="Quantidade" Title="Qtd pedida" Width="120px" TextAlign="TextAlign.Right">
                                            <Template Context="o"><strong>@o.Quantidade.ToString("N0")</strong></Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            }
                        </RadzenTabsItem>
                    </Tabs>
                </RadzenTabs>
            </RadzenStack>
        </RadzenCard>
    }
</RadzenStack>

@code {
    private const string ClassicPolicyName = "emax-eseg";
    private const string ForecastPolicyName = "forecast-rop";
    private static readonly string[] _dimensions = ["Categoria", "ClasseAbc", "Loja", "UF"];

    private const string TipPagina =
        "Replay de compras: para cada SKU×loja, simulamos dia-a-dia o que aconteceria sob duas políticas " +
        "— eMax/eSeg clássico (média histórica × LT) e ROP+forecast (LightGBM acumulado + safety por resíduo). " +
        "Comparação justa: mesmo estoque inicial, mesma demanda real, mesma janela.";
    private const string TipTreino =
        "Qual modelo de previsão treinado a política de ML vai usar. A simulação carrega esse modelo do MinIO para " +
        "prever a demanda futura. Só aparecem treinos concluídos. A política clássica (eMax/eSeg) não usa o modelo — " +
        "serve de comparação. Use o mesmo treino para comparações justas.";
    private const string TipJanela =
        "Quantos dias do passado a gente 'refaz' para testar as políticas. Ex.: 60 = simulamos as compras dos últimos " +
        "60 dias, dia a dia, como se cada política estivesse no comando. Maior janela = avaliação mais robusta, porém mais lenta.";
    private const string TipLeadTime =
        "Quantos dias o fornecedor demora entre o pedido e a entrega. Ex.: 7 = o que eu peço hoje só chega daqui a uma " +
        "semana — então preciso ter estoque para aguentar esse tempo. É o principal motor do estoque de segurança.";
    private const string TipCiclo =
        "De quantos em quantos dias eu reviso o estoque e faço um novo pedido. Ex.: 7 = compro uma vez por semana, " +
        "então cada pedido precisa cobrir o lead time + a semana até o próximo pedido.";
    private const string TipFator =
        "O quão 'caxias' eu sou contra faltar produto (estoque de segurança). É um número técnico (quantil da Normal): " +
        "1,65 ≈ aceito faltar só 5% das vezes (95% de serviço, padrão da farma); 1,28 ≈ 90%; 2,05 ≈ 98%. " +
        "Maior = menos ruptura, mas mais dinheiro parado em estoque.";
    private const string TipComparativo =
        "KPIs agregados de cada política em toda a janela. Nível de serviço alto + custo total baixo = sucesso. " +
        "Custo total = α × Σ estoque-dia + β × venda perdida (parâmetros documentados em SimulationOptions).";
    private const string TipNsUnid =
        "Fill rate — fração da demanda total atendida em unidades (1 − venda perdida / demanda). " +
        "É o KPI tradicional de serviço; pondera SKUs de alto giro.";
    private const string TipNsDias =
        "Cycle service level — fração de dia-SKU-loja sem ruptura (1 − dias com ruptura / dias totais). " +
        "Insensível ao volume — útil pra detectar ruptura crônica em itens de baixo giro.";
    private const string TipPerdida =
        "Unidades de demanda real que não foram atendidas (estoque insuficiente). É o que vira queixa do cliente e perda de venda.";
    private const string TipCobertura =
        "Dias de cobertura média = estoque médio / demanda diária média. " +
        "Reflete quanto capital fica parado em estoque — quanto menor, melhor (sem ruptura).";
    private const string TipGiro =
