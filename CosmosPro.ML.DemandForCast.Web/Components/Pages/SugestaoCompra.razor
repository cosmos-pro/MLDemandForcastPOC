    private List<TreinoOpt> _treinosConcluidos = [];
    private Guid _treinoJobId;
    private int _janelaDias = 60;
    private int _leadTime = 7;
    private int _ciclo = 7;
    private double _fatorServico = 1.65;

    private bool _enqueuing;
    private bool _loading;
    private bool _soItensAPedir = true;
    private string? _ledgerPolicy;
    private List<SimulacaoView> _jobs = [];
    private SimulacaoView? _selected;
    private Timer? _timer;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTreinosAsync();
        await RefreshAsync();
        _timer = new Timer(async _ => await InvokeAsync(RefreshAsync), null,
            TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    private async Task LoadTreinosAsync()
    {
        try
        {
            var jobs = await TrainingApi.ListAsync(50, _cts.Token);
            _treinosConcluidos = jobs
                .Where(j => j.Status == "Concluido")
                .Select(j => new TreinoOpt(j.Id, $"{j.DataAgendamento.ToLocalTime():dd/MM HH:mm} · {j.MaxSkus} SKUs · {j.Id.ToString()[..8]}"))
                .ToList();
            if (_treinoJobId == Guid.Empty && _treinosConcluidos.Count > 0)
                _treinoJobId = _treinosConcluidos[0].Id;
        }
        catch { /* POC: silencia */ }
    }

    private async Task RefreshAsync()
    {
        if (_loading) return;
        _loading = true;
        try
        {
            _jobs = [.. await PurchasingApi.ListAsync(50, _cts.Token)];
        }
        catch (OperationCanceledException) { }
        catch { /* POC: silencia polling */ }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnSelect(SimulacaoView j)
    {
        _selected = j.Status == "Concluido" && j.ResultadoJson is null
            ? await PurchasingApi.GetAsync(j.Id, _cts.Token) ?? j
            : j;
    }

    private async Task Simular()
    {
        if (_treinoJobId == Guid.Empty) return;
        _enqueuing = true;
        try
        {
            var job = await PurchasingApi.EnqueueAsync(new EnqueueSimulationRequest(
                _treinoJobId, _janelaDias, _leadTime, _ciclo, _fatorServico), _cts.Token);
            if (job is not null)
            {
                Notifications.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Simulação enfileirada",
                    Detail = $"Janela {_janelaDias}d · LT {_leadTime}d · ciclo {_ciclo}d · z {_fatorServico:F2}.",
                    Duration = 5000,
                });
                await RefreshAsync();
            }
        }
        catch (Exception ex)
        {
            Notifications.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error, Summary = "Falha ao enfileirar", Detail = ex.Message, Duration = 8000,
            });
        }
        finally { _enqueuing = false; }
    }

    private async Task Exportar(SimulationOutput so, Func<SimulationOutput, byte[]> build, string fileName)
    {
        try
        {
            var bytes = build(so);
            await JS.InvokeVoidAsync("downloadFile", fileName,
                Convert.ToBase64String(bytes), PurchasingExcelExporter.XlsxContentType);
        }
        catch (Exception ex)
        {
            Notifications.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error, Summary = "Falha ao exportar", Detail = ex.Message, Duration = 8000,
            });
        }
    }

    private static BadgeStyle BadgeFor(string status) => status switch
    {
        "Pendente" => BadgeStyle.Secondary,
        "Processando" => BadgeStyle.Info,
        "Concluido" => BadgeStyle.Success,
        "Falha" => BadgeStyle.Danger,
        _ => BadgeStyle.Light,
    };

    /// <summary>
    /// Pivota o KPI por dimensão: cada chave (ex.: "OTC", "A", "1", "SP") vira uma
    /// linha com NS e custo de cada política, e o vencedor por custo total.
    /// </summary>
    private static IReadOnlyList<DrillRow> BuildDrillRows(IReadOnlyList<PolicySimulationResultView> politicas, string dim)
    {
        var keys = politicas
            .SelectMany(p => p.PorDimensao is null ? [] :
                p.PorDimensao.TryGetValue(dim, out var d) ? d.Keys : (IEnumerable<string>)[])
            .Distinct()
            .ToList();

        var rows = new List<DrillRow>(keys.Count);
        foreach (var key in keys)
        {
            var ns = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
            var custo = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
            int dias = 0;
            string venc = "";
            decimal menorCusto = decimal.MaxValue;
            foreach (var p in politicas)
            {
                if (p.PorDimensao is null) continue;
                if (!p.PorDimensao.TryGetValue(dim, out var byKey)) continue;
                if (!byKey.TryGetValue(key, out var k)) continue;
                ns[p.Policy] = k.NivelServicoUnidades;
                custo[p.Policy] = k.CustoTotal;
                if (k.DiasTotais > dias) dias = k.DiasTotais;
                if (k.CustoTotal < menorCusto) { menorCusto = k.CustoTotal; venc = p.Policy; }
            }
            rows.Add(new DrillRow(key, dias, ns, custo, venc));
        }
        return rows.OrderByDescending(r => r.Dias).ThenBy(r => r.Chave, StringComparer.OrdinalIgnoreCase).ToList();
    }

    /// <summary>
    /// Funde a "foto do último dia" (ListaCompraFinal) das políticas por (SKU, loja):
    /// cada linha traz a posição e a quantidade sugerida de cada política, lado a lado.
    /// Ordena pela maior quantidade sugerida (itens mais urgentes no topo).
    /// </summary>
    private static IReadOnlyList<BuyRow> BuildBuyList(
        IReadOnlyList<PolicySimulationResultView> politicas,
        IReadOnlyDictionary<string, string> produtos)
    {
        var acc = new Dictionary<(string Sku, int Loja), (Dictionary<string, decimal> Pos, Dictionary<string, decimal> Qtd)>();
        foreach (var p in politicas)
        {
            foreach (var item in p.ListaCompraFinal ?? [])
            {
                var key = (item.Sku, item.LojaId);
                if (!acc.TryGetValue(key, out var entry))
                {
                    entry = (new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase),
                             new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase));
                    acc[key] = entry;
                }
                entry.Pos[p.Policy] = item.Posicao;
                entry.Qtd[p.Policy] = item.QuantidadeSugerida;
            }
        }

        return acc
            .Select(kv => new BuyRow(
                kv.Key.Sku,
                produtos.GetValueOrDefault(kv.Key.Sku) ?? "",
                kv.Key.Loja,
                kv.Value.Pos,
                kv.Value.Qtd))
            .OrderByDescending(b => b.QtdByPolicy.Values.DefaultIfEmpty(0m).Max())
            .ThenBy(b => b.Sku, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _cts.Cancel();
        _cts.Dispose();
    }
